---
import { type CollectionEntry, getCollection, render } from "astro:content";
import ZenLayout from "@layouts/ZenLayout.astro";
import SiteHeader from "@components/SiteHeader.astro";
import PageHeader from "@components/PageHeader.astro";
import { readingTime } from "@lib/utils";

export async function getStaticPaths() {
  const allEntries = (await getCollection("projects"))
    .filter((entry) => !entry.data.draft);
  return allEntries.map((entry) => ({
    params: { id: entry.id },
    props: entry,
  }));
}

type Props = CollectionEntry<"projects">;

const entry = Astro.props;
const { Content } = await render(entry);
const isNote = entry.id.includes("/");
const projectSlug = isNote ? entry.id.split("/")[0] : entry.id;

const allEntries = await getCollection("projects");
const notes = isNote
  ? []
  : allEntries
      .filter((e) => !e.data.draft && e.id.startsWith(projectSlug + "/"))
      .sort((a, b) => a.data.date.valueOf() - b.data.date.valueOf());

const dateLong = entry.data.date.toLocaleDateString("en-US", {
  month: "long",
  day: "numeric",
  year: "numeric",
});

const parentProject = isNote
  ? allEntries.find((e) => e.id === projectSlug)
  : null;
---

<ZenLayout title={entry.data.title} description={entry.data.description}>
  <SiteHeader active="projects" />

  <article>
    <PageHeader
      date={dateLong}
      title={entry.data.title}
      readingTime={entry.body ? readingTime(entry.body) : undefined}
      backLink={isNote && parentProject ? { href: `/projects/${projectSlug}`, label: parentProject.data.title } : undefined}
    >
      {!isNote && (entry.data.demoURL || entry.data.repoURL) && (
        <nav class="project-links">
          {entry.data.demoURL && (
            <a href={entry.data.demoURL} target="_blank" rel="noopener" class="project-link">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6" />
                <polyline points="15 3 21 3 21 9" />
                <line x1="10" y1="14" x2="21" y2="3" />
              </svg>
              demo
            </a>
          )}
          {entry.data.repoURL && (
            <a href={entry.data.repoURL} target="_blank" rel="noopener" class="project-link">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <polyline points="16 18 22 12 16 6" />
                <polyline points="8 6 2 12 8 18" />
              </svg>
              source
            </a>
          )}
        </nav>
      )}
    </PageHeader>

    <div class="zen-article">
      <Content />
    </div>

    {!isNote && notes.length > 0 && (
      <section class="project-notes">
        <h2 class="zen-h2">notes</h2>
        {notes.map((note) => (
          <>
            <h3 class="entry-title">
              <a href={`/projects/${note.id}`}>{note.data.title}</a>
            </h3>
            {note.data.description && (
              <p class="entry-desc">{note.data.description}</p>
            )}
          </>
        ))}
      </section>
    )}
  </article>
</ZenLayout>

<style>
  .project-links {
    display: flex;
    gap: 8px;
    align-items: center;
  }

  .project-link {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    margin-top: 10px;
    color: var(--c-meta);
    text-decoration: none;
  }

  .project-link:hover {
    color: var(--c-link);
    opacity: 1;
  }

  .project-link svg {
    width: 13px;
    height: 13px;
    flex-shrink: 0;
  }

  .project-notes {
    margin-top: 3rem;
  }

  .project-notes :global(.entry-title:first-of-type) {
    margin-top: 0;
  }
</style>
