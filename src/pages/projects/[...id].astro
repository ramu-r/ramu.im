---
import { type CollectionEntry, getCollection, render } from "astro:content";
import ZenLayout from "@layouts/ZenLayout.astro";
import SiteHeader from "@components/SiteHeader.astro";
import { readingTime } from "@lib/utils";

export async function getStaticPaths() {
  const projects = (await getCollection("projects"))
    .filter((post) => !post.data.draft)
    .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
  return projects.map((project) => ({
    params: { id: project.id },
    props: project,
  }));
}
type Props = CollectionEntry<"projects">;

const project = Astro.props;
const { Content } = await render(project);

const dateLong = project.data.date.toLocaleDateString("en-US", {
  month: "long",
  day: "numeric",
  year: "numeric",
});
---

<ZenLayout title={project.data.title} description={project.data.description}>
  <SiteHeader active="projects" />

  <article>
    <div class="post-meta">
      <span>{dateLong}</span>
      {project.body && <span>{readingTime(project.body)}</span>}
    </div>

    <h1 class="post-title">{project.data.title}</h1>

    {(project.data.demoURL || project.data.repoURL) && (
      <nav class="project-links">
        {project.data.demoURL && (
          <a href={project.data.demoURL} target="_blank" rel="noopener">demo</a>
        )}
        {project.data.demoURL && project.data.repoURL && <span class="sep">/</span>}
        {project.data.repoURL && (
          <a href={project.data.repoURL} target="_blank" rel="noopener">repo</a>
        )}
      </nav>
    )}

    <div class="zen-article">
      <Content />
    </div>
  </article>
</ZenLayout>

<style>
  .post-meta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 12px;
    font-size: 0.82rem;
    color: var(--c-meta);
    margin-bottom: 1.2rem;
  }

  .post-title {
    font-size: 2.4rem;
    font-weight: 700;
    letter-spacing: -0.03em;
    line-height: 1.1;
    margin: 0 0 0.8rem;
  }

  .project-links {
    display: flex;
    gap: 10px;
    align-items: center;
    margin-bottom: 2rem;
    font-size: 0.95rem;
  }

  .project-links .sep { color: var(--c-meta); }
</style>
