---
import { type CollectionEntry, getCollection, render } from "astro:content";
import ZenLayout from "@layouts/ZenLayout.astro";
import SiteHeader from "@components/SiteHeader.astro";
import { readingTime } from "@lib/utils";

export async function getStaticPaths() {
  const allEntries = (await getCollection("projects"))
    .filter((entry) => !entry.data.draft);
  return allEntries.map((entry) => ({
    params: { id: entry.id },
    props: entry,
  }));
}

type Props = CollectionEntry<"projects">;

const entry = Astro.props;
const { Content } = await render(entry);
const isNote = entry.id.includes("/");
const projectSlug = isNote ? entry.id.split("/")[0] : entry.id;

const allEntries = await getCollection("projects");
const notes = isNote
  ? []
  : allEntries
      .filter((e) => !e.data.draft && e.id.startsWith(projectSlug + "/"))
      .sort((a, b) => a.data.date.valueOf() - b.data.date.valueOf());

const dateLong = entry.data.date.toLocaleDateString("en-US", {
  month: "long",
  day: "numeric",
  year: "numeric",
});

const parentProject = isNote
  ? allEntries.find((e) => e.id === projectSlug)
  : null;
---

<ZenLayout title={entry.data.title} description={entry.data.description}>
  <SiteHeader active="projects" />

  <article>
    {isNote && parentProject && (
      <div class="back-link">
        <a href={`/projects/${projectSlug}`}>← {parentProject.data.title}</a>
      </div>
    )}

    <div class="post-meta">
      <span>{dateLong}</span>
      {entry.body && <span>{readingTime(entry.body)}</span>}
    </div>

    <h1 class="post-title">{entry.data.title}</h1>

    {!isNote && (entry.data.demoURL || entry.data.repoURL) && (
      <nav class="project-links">
        {entry.data.demoURL && (
          <a href={entry.data.demoURL} target="_blank" rel="noopener">demo</a>
        )}
        {entry.data.demoURL && entry.data.repoURL && <span class="sep">/</span>}
        {entry.data.repoURL && (
          <a href={entry.data.repoURL} target="_blank" rel="noopener">repo</a>
        )}
      </nav>
    )}

    <div class="zen-article">
      <Content />
    </div>

    {!isNote && notes.length > 0 && (
      <section class="project-notes">
        <h2 class="zen-h2">notes</h2>
        {notes.map((note) => (
          <a href={`/projects/${note.id}`} class="project-note">
            <span class="entry-title project-note-title">{note.data.title}</span>
            {note.data.description && (
              <span class="entry-desc project-note-desc">{note.data.description}</span>
            )}
          </a>
        ))}
      </section>
    )}
  </article>
</ZenLayout>

<style>
  .back-link {
    font-size: 0.85rem;
    margin-bottom: 1.6rem;
    color: var(--c-meta);
  }

  .back-link a {
    color: var(--c-meta);
    text-decoration: none;
  }

  .back-link a:hover {
    color: var(--c-fg);
    opacity: 1;
  }

  .post-meta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 12px;
    font-size: 0.82rem;
    color: var(--c-meta);
    margin-bottom: 1.2rem;
  }

  .post-title {
    font-size: 2.4rem;
    font-weight: 700;
    letter-spacing: -0.03em;
    line-height: 1.1;
    margin: 0 0 0.8rem;
  }

  .project-links {
    display: flex;
    gap: 10px;
    align-items: center;
    margin-bottom: 2rem;
    font-size: 0.95rem;
  }

  .project-links .sep { color: var(--c-meta); }

  .project-notes {
    margin-top: 3rem;
  }

  .project-note {
    display: block;
    text-decoration: none;
  }

  .project-note + .project-note {
    margin-top: 1.4rem;
  }

  .project-note .project-note-title {
    display: block;
    margin: 0;
    font-size: 0.98rem;
    font-weight: 600;
    color: var(--c-fg);
    text-decoration-line: underline;
    text-underline-offset: 3px;
    text-decoration-thickness: 1px;
    text-decoration-color: var(--c-link);
  }

  .project-note:hover .project-note-title {
    color: var(--c-link);
    text-decoration-color: var(--c-link);
  }

  .project-note .project-note-desc {
    display: block;
    margin-top: 0.25rem;
  }
</style>
