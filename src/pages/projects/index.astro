---
import { getCollection } from "astro:content";
import ZenLayout from "@layouts/ZenLayout.astro";
import SiteHeader from "@components/SiteHeader.astro";
import { PROJECTS } from "@consts";

const projects = (await getCollection("projects"))
  .filter((project) => !project.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<ZenLayout title={PROJECTS.TITLE} description={PROJECTS.DESCRIPTION}>
  <SiteHeader active="projects" />

  <h1 class="page-title">Projects</h1>

  <section>
    {projects.map((project) => (
      <>
        <h3 class="entry-title">
          <a href={`/projects/${project.id}`}>{project.data.title}</a>
        </h3>
        <p class="entry-desc">{project.data.description}</p>
      </>
    ))}
  </section>
</ZenLayout>

<style>
  .page-title {
    font-size: 2.2rem;
    font-weight: 700;
    letter-spacing: -0.02em;
    margin: 0 0 2.4rem;
  }

  section :global(.entry-title:first-of-type) {
    margin-top: 0;
  }
</style>
