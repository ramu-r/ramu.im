---
import { getCollection } from "astro:content";
import ZenLayout from "@layouts/ZenLayout.astro";
import SiteHeader from "@components/SiteHeader.astro";

export async function getStaticPaths() {
  const posts = await getCollection("blog", ({ data }) => !data.draft);
  const tags = [...new Set(posts.flatMap((post) => post.data.tags || []))];
  return tags.map((tag) => ({
    params: { id: tag },
    props: {
      posts: posts.filter((post) => post.data.tags?.includes(tag)),
    },
  }));
}

const { id } = Astro.params;
const { posts } = Astro.props;

const sortedPosts = posts.sort(
  (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime(),
);

const monthDay = (d: Date) =>
  d.toLocaleDateString("en-US", { month: "short", day: "numeric", year: "numeric" });
---

<ZenLayout title={`Tag: ${id}`} description={`Posts with the tag: ${id}`}>
  <SiteHeader active="tags" />

  <h1 class="page-title">#{id}</h1>

  <section>
    {sortedPosts.map((post) => (
      <>
        <h3 class="entry-title">
          <a href={`/blog/${post.id}`}>{post.data.title || post.data.description}</a>
          {" "}<span class="entry-date">{monthDay(post.data.date)}</span>
        </h3>
        {post.data.title && post.data.description && (
          <p class="entry-desc">{post.data.description}</p>
        )}
      </>
    ))}
  </section>

  <p class="back"><a href="/tags">← all tags</a></p>
</ZenLayout>

<style>
  .page-title {
    font-size: 2.2rem;
    font-weight: 700;
    letter-spacing: -0.02em;
    margin: 0 0 2.4rem;
  }

  section :global(.entry-title:first-of-type) {
    margin-top: 0;
  }

  .back {
    margin-top: 2.4rem;
    font-size: 0.9rem;
  }
</style>
