---
import { getCollection } from "astro:content";
import ZenLayout from "@layouts/ZenLayout.astro";
import SiteHeader from "@components/SiteHeader.astro";

const posts = await getCollection("blog", ({ data }) => !data.draft);
const tags = [...new Set(posts.flatMap((post) => post.data.tags || []))].sort();
const count = (tag: string) =>
  posts.filter((post) => post.data.tags?.includes(tag)).length;
---

<ZenLayout title="Tags" description="List of tags used.">
  <SiteHeader active="tags" />

  <h1 class="page-title">Tags</h1>

  <div class="tag-cloud">
    {tags.map((tag) => (
      <a href={`/tags/${tag}`} class="tag-chip">
        {tag} <span class="tag-count">{count(tag)}</span>
      </a>
    ))}
  </div>
</ZenLayout>

<style>
  .page-title {
    font-size: 2.2rem;
    font-weight: 700;
    letter-spacing: -0.02em;
    margin: 0 0 2.4rem;
  }

  .tag-cloud {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
  }

  .tag-chip {
    font-size: 0.9rem;
    color: var(--c-fg);
    text-decoration: none;
    border: 1px solid var(--c-divider);
    border-radius: 99px;
    padding: 5px 14px;
    transition: border-color 0.15s;
  }

  .tag-chip:hover {
    opacity: 1;
    border-color: var(--c-meta);
  }

  .tag-count { color: var(--c-meta); font-size: 0.82rem; }
</style>
