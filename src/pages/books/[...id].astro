---
import { type CollectionEntry, getCollection, render } from "astro:content";
import { Image } from "astro:assets";
import ZenLayout from "@layouts/ZenLayout.astro";
import SiteHeader from "@components/SiteHeader.astro";
import { readingTime } from "@lib/utils";

export async function getStaticPaths() {
  const books = (await getCollection("books"))
    .filter((book) => !book.data.draft)
    .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
  return books.map((book) => ({
    params: { id: book.id },
    props: book,
  }));
}
type Props = CollectionEntry<"books">;

const book = Astro.props;
const { Content } = await render(book);

const dateLong = book.data.date.toLocaleDateString("en-US", {
  month: "long",
  day: "numeric",
  year: "numeric",
});
---

<ZenLayout title={book.data.title} description={book.data.excerpt}>
  <SiteHeader />

  <article>
    <div class="post-meta">
      <span>{dateLong}</span>
      {book.body && <span>{readingTime(book.body)}</span>}
    </div>

    <div class="book-head">
      <Image src={book.data.cover} alt={`Cover of ${book.data.title}`} class="book-cover" width={160} />
      <div>
        <h1 class="post-title">{book.data.title}</h1>
        <p class="book-author">{book.data.author}</p>
      </div>
    </div>

    <div class="zen-article">
      <Content />
    </div>
  </article>
</ZenLayout>

<style>
  .post-meta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 12px;
    font-size: 0.82rem;
    color: var(--c-meta);
    margin-bottom: 1.2rem;
  }

  .book-head {
    display: flex;
    align-items: flex-start;
    gap: 1.4rem;
    margin-bottom: 2rem;
  }

  .book-cover {
    width: 110px;
    height: auto;
    border-radius: 3px;
    box-shadow: 0 1px 8px rgba(0, 0, 0, 0.18);
    flex-shrink: 0;
  }

  .post-title {
    font-size: 2.1rem;
    font-weight: 700;
    letter-spacing: -0.03em;
    line-height: 1.1;
    margin: 0 0 0.4rem;
  }

  .book-author {
    margin: 0;
    font-size: 1rem;
    color: var(--c-desc);
  }
</style>
