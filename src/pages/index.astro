---
import ZenLayout from "@layouts/ZenLayout.astro";
import HomeHeader from "@components/HomeHeader.astro";
import WritingSection from "@components/WritingSection.astro";
import NotesSection from "@components/NotesSection.astro";
import BooksSection from "@components/BooksSection.astro";
import ProjectsSection from "@components/ProjectsSection.astro";
import { SITE, HOME, AUTHOR } from "@consts";
import { getCollection } from "astro:content";

const all = (await getCollection("blog"))
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const NUM_NOTES_ON_HOMEPAGE = 5;
const NUM_PROJECT_NOTES_ON_HOMEPAGE = 3;

const allProjectEntries = (await getCollection("projects"))
  .filter((entry) => !entry.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const allProjects = allProjectEntries.filter((e) => !e.id.includes("/"));
const projects = allProjects.slice(0, SITE.NUM_PROJECTS_ON_HOMEPAGE);
const hasMoreProjects = allProjects.length > SITE.NUM_PROJECTS_ON_HOMEPAGE;

const projectNotesMap = Object.fromEntries(
  projects.map((project) => [
    project.id,
    allProjectEntries
      .filter((e) => e.id.startsWith(project.id + "/"))
      .sort((a, b) => a.data.date.valueOf() - b.data.date.valueOf()),
  ])
);

const allBooks = (await getCollection("books"))
  .filter((book) => !book.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
const books = allBooks.slice(0, SITE.NUM_BOOKS_ON_HOMEPAGE);
const hasMoreBooks = allBooks.length > SITE.NUM_BOOKS_ON_HOMEPAGE;

const allWriting = all.filter((p) => p.data.type !== "micro");
const writing = allWriting.slice(0, SITE.NUM_POSTS_ON_HOMEPAGE);
const hasMoreWriting = allWriting.length > SITE.NUM_POSTS_ON_HOMEPAGE;

const allNotes = all.filter((p) => p.data.type === "micro");
const notes = allNotes.slice(0, NUM_NOTES_ON_HOMEPAGE);
const hasMoreNotes = allNotes.length > NUM_NOTES_ON_HOMEPAGE;

const monthYear = (d: Date) =>
  d.toLocaleDateString("en-US", { month: "short", year: "numeric" });
const fullDate = (d: Date) =>
  d.toLocaleDateString("en-US", { month: "short", day: "numeric", year: "numeric" });
---

<ZenLayout title={HOME.TITLE} description={SITE.DESCRIPTION}>
  <HomeHeader
    firstName={AUTHOR.NAME.split(" ")[0]}
    tagline={AUTHOR.TAGLINE}
    bio={AUTHOR.BIO[0]}
  />

  <div class="cols">
    <WritingSection posts={writing} hasMore={hasMoreWriting} monthYear={monthYear} />
    <NotesSection notes={notes} hasMore={hasMoreNotes} fullDate={fullDate} />
  </div>

  <BooksSection books={books} hasMore={hasMoreBooks} />
  <ProjectsSection
    projects={projects}
    projectNotesMap={projectNotesMap}
    hasMore={hasMoreProjects}
    numProjectNotesOnHomepage={NUM_PROJECT_NOTES_ON_HOMEPAGE}
  />
</ZenLayout>

<style>
  .cols {
    display: flex;
    gap: 4em;
    margin-bottom: 1rem;
  }

  :global(.writing) {
    flex: 1 1 65%;
  }

  :global(.notes) {
    flex: 1 1 45%;
  }

  @media (max-width: 640px) {
    .cols {
      flex-direction: column;
      gap: 2.6rem;
    }
  }
</style>
