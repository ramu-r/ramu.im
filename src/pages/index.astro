---
import ZenLayout from "@layouts/ZenLayout.astro";
import SocialIcons from "@components/SocialIcons.astro";
import { Image } from "astro:assets";
import { SITE, HOME, AUTHOR } from "@consts";
import { getCollection } from "astro:content";

const all = (await getCollection("blog"))
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const NUM_NOTES_ON_HOMEPAGE = 5;
const NUM_PROJECT_NOTES_ON_HOMEPAGE = 3;

const allProjectEntries = (await getCollection("projects"))
  .filter((entry) => !entry.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const allProjects = allProjectEntries.filter((e) => !e.id.includes("/"));
const projects = allProjects.slice(0, SITE.NUM_PROJECTS_ON_HOMEPAGE);
const hasMoreProjects = allProjects.length > SITE.NUM_PROJECTS_ON_HOMEPAGE;

const projectNotesMap = Object.fromEntries(
  projects.map((project) => [
    project.id,
    allProjectEntries
      .filter((e) => e.id.startsWith(project.id + "/"))
      .sort((a, b) => a.data.date.valueOf() - b.data.date.valueOf()),
  ])
);

const allBooks = (await getCollection("books"))
  .filter((book) => !book.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
const books = allBooks.slice(0, SITE.NUM_BOOKS_ON_HOMEPAGE);
const hasMoreBooks = allBooks.length > SITE.NUM_BOOKS_ON_HOMEPAGE;

const allWriting = all.filter((p) => p.data.type !== "micro");
const writing = allWriting.slice(0, SITE.NUM_POSTS_ON_HOMEPAGE);
const hasMoreWriting = allWriting.length > SITE.NUM_POSTS_ON_HOMEPAGE;

const allNotes = all.filter((p) => p.data.type === "micro");
const notes = allNotes.slice(0, NUM_NOTES_ON_HOMEPAGE);
const hasMoreNotes = allNotes.length > NUM_NOTES_ON_HOMEPAGE;

const monthYear = (d: Date) =>
  d.toLocaleDateString("en-US", { month: "short", year: "numeric" });
const fullDate = (d: Date) =>
  d.toLocaleDateString("en-US", { month: "short", day: "numeric", year: "numeric" });
---

<ZenLayout title={HOME.TITLE} description={SITE.DESCRIPTION}>
  <!-- <span class="zen-logo home-logo" aria-hidden="true"></span> -->

  <h1 class="home-name">I'm {AUTHOR.NAME.split(" ")[0]}</h1>
  <p class="byline">{AUTHOR.TAGLINE}</p>
  <p class="bio">{AUTHOR.BIO[0]}</p>

  <SocialIcons />

  <div class="cols">
    <section class="writing">
      <h2 class="zen-h2"><a href="/blog">writing</a></h2>
      {writing.map((post) => (
        <>
          <h3 class="entry-title">
            <a href={`/blog/${post.id}`}>{post.data.title || post.data.description}</a>
            {" "}<span class="entry-date">{monthYear(post.data.date)}</span>
          </h3>
          {post.data.title && post.data.description && (
            <p class="entry-desc">{post.data.description}</p>
          )}
        </>
      ))}
      {hasMoreWriting && (
        <div class="all-row">
          <a href="/blog" class="all-link">see more <span class="arrow">→</span></a>
        </div>
      )}
    </section>

    <section class="notes">
      <h2 class="zen-h2"><a href="/feed">feed</a></h2>
      {notes.length === 0 && (
        <p class="entry-desc">No notes yet.</p>
      )}
      {notes.map((note) => (
        <div class="note">
          <p class="note-text">{note.data.description}</p>
          {note.data.link && (
            <a href={note.data.link.url} class="note-link-card" target="_blank" rel="noopener">
              <span class="link-title">{note.data.link.title}</span>
              <span class="link-domain">{new URL(note.data.link.url).hostname.replace(/^www\./, "")}</span>
            </a>
          )}
          <div class="note-footer">
            <span class="note-meta">{fullDate(note.data.date)}</span>
            {note.body && note.body.trim() && (
              <a href={`/blog/${note.id}`} class="note-more">see more <span class="arrow">→</span></a>
            )}
          </div>
        </div>
      ))}
      {hasMoreNotes && (
        <div class="all-row">
          <a href="/feed" class="all-link">see more <span class="arrow">→</span></a>
        </div>
      )}
    </section>
  </div>

  {books.length > 0 && (
    <section class="books">
      <h2 class="zen-h2"><a href="/books">reading</a></h2>
      {books.map((book) => (
        <div class="book-row">
          <a href={`/books/${book.id}`} class="book-cover-link">
            <Image src={book.data.cover} alt={`Cover of ${book.data.title}`} class="book-cover" width={200} />
          </a>
          <div class="book-body">
            <h3 class="entry-title book-title">
              <a href={`/books/${book.id}`}>{book.data.title}</a>
            </h3>
            <p class="book-author">{book.data.author}</p>
            <p class="entry-desc book-excerpt">{book.data.excerpt}</p>
          </div>
        </div>
      ))}
      {hasMoreBooks && (
        <div class="all-row">
          <a href="/books" class="all-link">see more <span class="arrow">→</span></a>
        </div>
      )}
    </section>
  )}

  {projects.length > 0 && (
    <section class="projects">
      <h2 class="zen-h2"><a href="/projects">process notes</a></h2>
      {projects.map((project) => (
        <div class="project-row">
          <div class="project-info">
            <h3 class="entry-title project-title">
              <a href={`/projects/${project.id}`}>{project.data.title}</a>
            </h3>
            <p class="entry-desc">{project.data.description}</p>
            <div class="project-links">
              {project.data.repoURL && (
                <a href={project.data.repoURL} target="_blank" rel="noopener">GitHub</a>
              )}
              {project.data.demoURL && (
                <a href={project.data.demoURL} target="_blank" rel="noopener">Demo</a>
              )}
            </div>
          </div>
          <div class="project-notes">
            {projectNotesMap[project.id]?.slice(0, NUM_PROJECT_NOTES_ON_HOMEPAGE).map((note) => (
              <a href={`/projects/${note.id}`} class="project-note">
                <span class="entry-title project-note-title">{note.data.title}</span>
              </a>
            ))}
            {(projectNotesMap[project.id]?.length ?? 0) > NUM_PROJECT_NOTES_ON_HOMEPAGE && (
              <div class="all-row">
                <a href={`/projects/${project.id}`} class="all-link">see more <span class="arrow">→</span></a>
              </div>
            )}
          </div>
        </div>
      ))}
      {hasMoreProjects && (
        <div class="all-row">
          <a href="/projects" class="all-link">see more <span class="arrow">→</span></a>
        </div>
      )}
    </section>
  )}
</ZenLayout>

<style>
  .home-logo {
    display: block;
    margin-bottom: 2.6rem;
  }

  .home-name {
    font-size: 3rem;
    font-weight: 700;
    letter-spacing: -0.03em;
    margin: 0 0 0.5rem;
    line-height: 1.05;
  }

  .byline {
    margin: 0 0 0.7rem;
    font-size: 1.05rem;
    color: var(--c-desc);
  }

  .bio {
    margin: 0 0 1.8rem;
    font-size: 1rem;
    color: var(--c-desc);
    line-height: 1.6;
    max-width: 520px;
  }

  .books {
    margin-top: 5rem;
  }

  .book-row {
    display: flex;
    align-items: flex-start;
    gap: 1.6rem;
  }

  .book-row + .book-row {
    margin-top: 2rem;
  }

  .book-cover-link {
    flex-shrink: 0;
    line-height: 0;
  }

  .book-cover {
    width: 100px;
    height: auto;
    border-radius: 3px;
    box-shadow: 0 1px 6px rgba(0, 0, 0, 0.16);
  }

  .book-body {
    flex: 1;
    min-width: 0;
  }

  .book-title {
    margin: 0;
  }

  .book-author {
    margin: 0.2rem 0 0;
    font-size: 0.85rem;
    color: var(--c-meta);
  }

  .book-excerpt {
    margin: 0.7rem 0 0;
    max-width: 60ch;
  }

  .projects {
    margin-top: 5rem;
  }

  .project-row {
    display: flex;
    gap: 2em;
  }

  .project-row + .project-row {
    margin-top: 2rem;
    padding-top: 2rem;
    border-top: 1px solid var(--c-divider);
  }

  .project-info { flex: 3 1 0; min-width: 0; }
  .project-notes { flex: 2 1 0; }

  .project-title {
    margin-top: 0;
    font-size: 1.3rem;
    font-weight: 700;
    letter-spacing: -0.02em;
  }

  .project-links {
    display: flex;
    gap: 1.1rem;
    margin-top: 0.7rem;
  }

  .project-links a {
    font-size: 0.85rem;
    color: var(--c-meta);
    text-decoration: none;
  }

  .project-links a:hover { color: var(--c-fg); }

  .project-note {
    display: block;
    text-decoration: none;
  }

  .project-note + .project-note {
    margin-top: 1.4rem;
  }

  .project-note .project-note-title {
    display: block;
    margin: 0;
    font-size: 0.98rem;
    font-weight: 600;
    color: var(--c-fg);
    text-decoration-line: underline;
    text-underline-offset: 3px;
    text-decoration-thickness: 1px;
    text-decoration-color: var(--c-link);
  }

  .project-note:hover .project-note-title {
    color: var(--c-link);
    text-decoration-color: var(--c-link);
  }

  .project-note .project-note-desc {
    display: block;
    margin-top: 0.25rem;
  }

  .cols {
    display: flex;
    gap: 4em;
    margin-bottom: 1rem;
  }

  .writing { flex: 1 1 65%; }
  .notes { flex: 1 1 45%; }

  @media (max-width: 640px) {
    .cols {
      flex-direction: column;
      gap: 2.6rem;
    }
    .project-row {
      flex-direction: column;
      gap: 1.6rem;
    }
    .home-name { font-size: 2.4rem; }
  }

  .writing :global(.entry-title:first-of-type) {
    margin-top: 0;
  }

  .notes :global(.note:first-of-type) {
    padding-top: 0;
  }

  .zen-h2 :global(a) {
    color: inherit;
    text-decoration: none;
  }

  .zen-h2 :global(a:hover) {
    color: var(--c-fg);
    opacity: 1;
  }

  .all-row {
    margin-top: 1.6rem;
    text-align: right;
  }

  .all-link {
    font-size: 0.85rem;
    color: var(--c-meta);
    text-decoration: none;
  }

  .all-link:hover { color: var(--c-fg); opacity: 1; }

  .all-link .arrow { color: var(--c-link); }

  .note-footer {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1rem;
    margin-top: 6px;
  }

  .note-more {
    font-size: 0.85rem;
    color: var(--c-meta);
    text-decoration: none;
  }

  .note-more:hover { color: var(--c-fg); opacity: 1; }

  .note-more .arrow { color: var(--c-link); }

  .note-link-card {
    display: block;
    text-decoration: none;
    margin-top: 6px;
  }

  .note-link-card:hover { opacity: 0.65; }

  .note-link-card :global(.link-title) {
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--c-fg);
    text-decoration-line: underline;
    text-underline-offset: 3px;
    text-decoration-thickness: 1px;
    text-decoration-color: var(--c-link);
  }

  .note-link-card:hover :global(.link-title) {
    color: var(--c-link);
  }

  .note-link-card :global(.link-domain) {
    font-size: 0.85rem;
    color: var(--c-meta);
  }

  .note-link-card :global(.link-domain)::before {
    content: " — ";
  }
</style>
