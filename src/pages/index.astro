---
import TwoPanelLayout from "@layouts/TwoPanelLayout.astro";
import PostCard from "@components/PostCard.astro";
import MicroCard from "@components/MicroCard.astro";
import { SITE, HOME, AUTHOR } from "@consts";
import { getCollection } from "astro:content";

const posts = (await getCollection("blog"))
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, SITE.NUM_POSTS_ON_HOMEPAGE);
---

<TwoPanelLayout title={HOME.TITLE} description={HOME.DESCRIPTION}>
  <div slot="left" class="feed-left">
    <div class="logo-circle" aria-hidden="true"></div>
    <a href="/" class="site-title-large">{SITE.TITLE}</a>
    <p class="site-bio">{SITE.DESCRIPTION}</p>

    <div class="year-label">Recent</div>
    <div class="post-list">
      {posts.map((post) =>
        post.data.type === "micro"
          ? <MicroCard entry={post} />
          : <PostCard entry={post} />
      )}
    </div>

    <div class="all-posts-row">
      <a href="/blog" class="all-posts-link">All posts →</a>
    </div>
  </div>

  <div slot="right" class="feed-right">
    <div class="right-author-name">{AUTHOR.NAME}</div>
    <div class="right-author-tagline">{AUTHOR.TAGLINE}</div>
    <div class="right-about">
      {AUTHOR.BIO.map(p => <p class="right-about-text">{p}</p>)}
      <a href={`mailto:${SITE.EMAIL}`} class="right-email">{SITE.EMAIL}</a>
    </div>
  </div>
</TwoPanelLayout>

<style>
  /* ── Left panel content ── */
  .feed-left {
    display: flex;
    flex-direction: column;
  }

  .logo-circle {
    width: 18px;
    height: 18px;
    border-radius: 50%;
    border: 1.5px solid var(--text-primary);
    margin-bottom: 36px;
    flex-shrink: 0;
  }

  .site-title-large {
    font-family: var(--serif);
    font-size: 22px;
    font-weight: 400;
    color: var(--text-primary);
    text-decoration: none;
    display: block;
    line-height: 1.2;
    letter-spacing: -0.01em;
    margin-bottom: 0;
  }

  .site-bio {
    font-size: 14px;
    font-weight: 300;
    color: var(--text-body);
    line-height: 1.8;
    max-width: 25rem;
    margin-top: 20px;
    margin-bottom: 52px;
    white-space: pre-line;
  }

  .year-label {
    font-size: 11px;
    font-weight: 500;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-bottom: 14px;
  }

  .post-list {
    display: flex;
    flex-direction: column;
    gap: 25px;
    max-width: 500px;
  }

  .all-posts-row {
    max-width: 500px;
    display: flex;
    justify-content: flex-end;
    margin-top: 16px;
  }

  .all-posts-link {
    font-size: 13px;
    font-weight: 400;
    color: var(--text-muted);
    text-decoration: none;
    transition: color 0.15s;
  }

  .all-posts-link:hover { color: var(--text-primary); }

  /* ── Right panel content ── */
  .feed-right {
    display: flex;
    flex-direction: column;
    height: 100%;
  }

  .right-author-name {
    font-family: var(--serif);
    font-size: 18px;
    font-weight: 400;
    color: var(--text-primary);
    letter-spacing: -0.01em;
    margin-bottom: 4px;
  }

  .right-author-tagline {
    font-size: 12.5px;
    font-weight: 300;
    color: var(--text-muted);
  }

  .right-about {
    margin-top: auto;
  }

  .right-about-text {
    font-size: 13px;
    font-weight: 300;
    color: var(--text-body);
    line-height: 1.7;
    margin-bottom: 14px;
  }

  .right-email {
    font-size: 12.5px;
    font-weight: 400;
    color: var(--text-muted);
    text-decoration: underline;
    text-decoration-color: var(--accent);
    text-underline-offset: 3px;
    transition: color 0.15s;
  }

  .right-email:hover { color: var(--text-primary); }
</style>
