---
import { type CollectionEntry, getCollection, render } from "astro:content";
import ZenLayout from "@layouts/ZenLayout.astro";
import SiteHeader from "@components/SiteHeader.astro";


export async function getStaticPaths() {
  const posts = (await getCollection("blog"))
    .filter((post) => !post.data.draft)
    .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
  return posts.map((post) => ({
    params: { id: post.id },
    props: post,
  }));
}

type Props = CollectionEntry<"blog">;

const posts = (await getCollection("blog"))
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const idx = posts.findIndex((p) => p.id === Astro.params.id);
const nextPost = posts[idx + 1];
const prevPost = posts[idx - 1];

const post = Astro.props;
const { Content } = await render(post);
const isMicro = post.data.type === "micro";

const dateLong = post.data.date.toLocaleDateString("en-US", {
  month: "long",
  day: "numeric",
  year: "numeric",
});

const navTitle = (p: CollectionEntry<"blog">) =>
  p.data.title || p.data.description;
---

<ZenLayout
  title={post.data.title || post.data.description}
  description={post.data.description}
>
  <SiteHeader active="blog" />

  <article>
    <div class="post-meta">
      <span>{dateLong}</span>
      {post.data.tags?.map((tag) => (
        <a href={`/tags/${tag}`} class="tag">#{tag}</a>
      ))}
    </div>

    {!isMicro && post.data.title && (
      <h1 class="post-title">{post.data.title}</h1>
    )}

    {isMicro && (
      <p class="micro-lead">{post.data.description}</p>
    )}

    <div class="zen-article">
      <Content />
    </div>
  </article>

  <nav class="post-nav">
    {prevPost ? (
      <a href={`/blog/${prevPost.id}`} class="post-nav-item">
        <span class="post-nav-label">← Previous</span>
        <span class="post-nav-title">{navTitle(prevPost)}</span>
      </a>
    ) : <span />}
    {nextPost ? (
      <a href={`/blog/${nextPost.id}`} class="post-nav-item next">
        <span class="post-nav-label">Next →</span>
        <span class="post-nav-title">{navTitle(nextPost)}</span>
      </a>
    ) : <span />}
  </nav>

</ZenLayout>

<style>
  .post-meta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 12px;
    font-size: 0.82rem;
    color: var(--c-meta);
    margin-bottom: 1.2rem;
  }

  .tag {
    color: var(--c-meta);
    text-decoration: none;
    background: var(--c-featured-bg);
    border-radius: 99px;
    padding: 2px 10px;
    font-size: 0.78rem;
  }

  .tag:hover { color: var(--c-fg); opacity: 1; }

  .post-title {
    font-size: 2.4rem;
    font-weight: 700;
    letter-spacing: -0.03em;
    line-height: 1.1;
    margin: 0 0 2rem;
  }

  .micro-lead {
    font-size: 1.5rem;
    font-style: italic;
    color: var(--c-fg);
    line-height: 1.5;
    margin: 0 0 2rem;
  }

  .post-nav {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 12px;
    margin-top: 3.5rem;
    padding-top: 2rem;
    border-top: 1px solid var(--c-divider);
  }

  .post-nav-item {
    display: flex;
    flex-direction: column;
    gap: 5px;
    text-decoration: none;
    padding: 14px 16px;
    border: 1px solid var(--c-divider);
    border-radius: 8px;
    transition: border-color 0.18s;
  }

  .post-nav-item:hover {
    opacity: 1;
    border-color: var(--c-meta);
  }

  .post-nav-item.next { text-align: right; }

  .post-nav-label {
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--c-meta);
  }

  .post-nav-title {
    font-size: 0.92rem;
    font-weight: 600;
    color: var(--c-fg);
    line-height: 1.35;
  }

  .comments {
    margin-top: 3.5rem;
  }
</style>
