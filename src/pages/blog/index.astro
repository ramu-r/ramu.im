---
import { type CollectionEntry, getCollection } from "astro:content";
import ZenLayout from "@layouts/ZenLayout.astro";
import SiteHeader from "@components/SiteHeader.astro";
import PageHeader from "@components/PageHeader.astro";
import { BLOG } from "@consts";

const data = (await getCollection("blog"))
  .filter((post) => !post.data.draft && post.data.type !== "micro")
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

type Acc = { [year: string]: CollectionEntry<"blog">[] };
const posts = data.reduce((acc: Acc, post) => {
  const year = post.data.date.getFullYear().toString();
  if (!acc[year]) acc[year] = [];
  acc[year].push(post);
  return acc;
}, {});
const years = Object.keys(posts).sort((a, b) => parseInt(b) - parseInt(a));

const monthDay = (d: Date) =>
  d.toLocaleDateString("en-US", { month: "short", day: "numeric" });
---

<ZenLayout title={BLOG.TITLE} description={BLOG.DESCRIPTION}>
  <SiteHeader active="blog" />

  <PageHeader title="Posts" description="Longer-form writing and notes on building with care." />

  {years.map((year) => (
    <section class="year-group">
      <h2 class="zen-h2">{year}</h2>
      {posts[year].map((post) => (
        <>
          <h3 class="entry-title">
            <a href={`/blog/${post.id}`}>{post.data.title || post.data.description}</a>
            {" "}<span class="entry-date">{monthDay(post.data.date)}</span>
          </h3>
          {post.data.title && post.data.description && (
            <p class="entry-desc">{post.data.description}</p>
          )}
        </>
      ))}
    </section>
  ))}
</ZenLayout>

<style>
  .year-group {
    margin-bottom: 2.8rem;
  }

  .year-group :global(.entry-title:first-of-type) {
    margin-top: 0;
  }
</style>
