---
import ZenLayout from "@layouts/ZenLayout.astro";
import { SITE } from "@consts";
---

<ZenLayout title="404" description={SITE.DESCRIPTION}>
  <div class="notfound">
    <span class="zen-logo" aria-hidden="true"></span>
    <h1>404</h1>
    <p>This page could not be found.</p>
    <a href="/">← Go home</a>
  </div>
</ZenLayout>

<style>
  .notfound {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 1rem;
    padding-top: 4rem;
  }

  .notfound h1 {
    font-size: 3rem;
    font-weight: 700;
    letter-spacing: -0.03em;
    margin: 0;
  }

  .notfound p {
    color: var(--c-desc);
    margin: 0;
  }
</style>
