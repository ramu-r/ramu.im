---
import type { CollectionEntry } from "astro:content";

interface Props {
  entry: CollectionEntry<"blog">;
}

const { entry } = Astro.props;
const href = `/${entry.collection}/${entry.id}`;
const dateShort = entry.data.date.toLocaleDateString("en-US", {
  month: "short",
  day: "numeric",
});
---

<a href={href} class="post-card">
  <div class="post-card-title">{entry.data.title || entry.data.description}</div>
  {entry.data.title && entry.data.description && (
    <div class="post-card-desc">{entry.data.description}</div>
  )}
  <div class="post-card-footer">
    <div class="tag-list">
      {entry.data.tags?.map((tag) => (
        <span class="tag">#{tag}</span>
      ))}
    </div>
    <span class="post-card-date">{dateShort}</span>
  </div>
</a>

<style>
  .post-card {
    display: flex;
    flex-direction: column;
    gap: 6px;
    text-decoration: none;
    background: var(--card-bg);
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 20px 22px;
    transition: background 0.18s, border-color 0.18s;
  }

  .post-card:hover {
    background: var(--card-bg-hover);
    border-color: rgba(80, 60, 30, 0.22);
  }

  .post-card-title {
    font-family: var(--serif);
    font-size: 15px;
    font-weight: 400;
    color: var(--text-primary);
    line-height: 1.4;
  }

  .post-card-desc {
    font-size: 13px;
    font-weight: 300;
    color: var(--text-muted);
    line-height: 1.55;
  }

  .post-card-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-top: 8px;
  }

  .tag-list {
    display: flex;
    gap: 5px;
    flex-wrap: wrap;
  }

  .tag {
    font-size: 11px;
    font-weight: 400;
    color: var(--text-muted);
    background: var(--tag-bg);
    border-radius: 99px;
    padding: 3px 10px;
  }

  .post-card-date {
    font-size: 11.5px;
    font-weight: 300;
    color: var(--text-muted);
    font-variant-numeric: tabular-nums;
    white-space: nowrap;
  }
</style>
