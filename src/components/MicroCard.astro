---
import type { CollectionEntry } from "astro:content";

interface Props {
  entry: CollectionEntry<"blog">;
}

const { entry } = Astro.props;
const href = `/${entry.collection}/${entry.id}`;
const dateShort = entry.data.date.toLocaleDateString("en-US", {
  month: "short",
  day: "numeric",
});
---

<a href={href} class="micro-card">
  <div class="micro-card-content">{entry.data.description}</div>
  <div class="micro-card-footer">
    <div class="tag-list">
      {entry.data.tags?.map((tag) => (
        <span class="tag">#{tag}</span>
      ))}
    </div>
    <span class="micro-card-date">{dateShort}</span>
  </div>
</a>

<style>
  .micro-card {
    display: flex;
    flex-direction: column;
    gap: 10px;
    text-decoration: none;
    background: var(--card-bg);
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 20px 22px;
    transition: background 0.18s, border-color 0.18s;
  }

  .micro-card:hover {
    background: var(--card-bg-hover);
    border-color: rgba(80, 60, 30, 0.22);
  }

  .micro-card-content {
    font-family: var(--serif);
    font-size: 14px;
    font-weight: 400;
    font-style: italic;
    color: var(--text-body);
    line-height: 1.65;
  }

  .micro-card-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-top: 4px;
  }

  .tag-list {
    display: flex;
    gap: 5px;
    flex-wrap: wrap;
  }

  .tag {
    font-size: 11px;
    font-weight: 400;
    color: var(--text-muted);
    background: var(--tag-bg);
    border-radius: 99px;
    padding: 3px 10px;
  }

  .micro-card-date {
    font-size: 11.5px;
    font-weight: 300;
    color: var(--text-muted);
    font-variant-numeric: tabular-nums;
    white-space: nowrap;
  }
</style>
