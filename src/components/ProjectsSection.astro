---
interface Props {
  projects: any[];
  projectNotesMap: Record<string, any[]>;
  hasMore: boolean;
  numProjectNotesOnHomepage: number;
}

const { projects, projectNotesMap, hasMore, numProjectNotesOnHomepage } = Astro.props;
---

{projects.length > 0 && (
  <section class="projects">
    <h2 class="zen-h2"><a href="/projects">projects</a></h2>
    {projects.map((project) => (
      <div class="project-block">
        <div class="project-header">
          <h3 class="entry-title project-title">
            <a href={`/projects/${project.id}`}>{project.data.title}</a>
          </h3>
          {(projectNotesMap[project.id]?.length ?? 0) > 0 && (
            <p class="project-notes-label">build log</p>
          )}
        </div>
        <div class="project-row">
          <div class="project-info">
            <p class="entry-desc">{project.data.description}</p>
            <div class="project-links">
              {project.data.repoURL && (
                <a href={project.data.repoURL} target="_blank" rel="noopener">GitHub</a>
              )}
              {project.data.demoURL && (
                <a href={project.data.demoURL} target="_blank" rel="noopener">Demo</a>
              )}
            </div>
          </div>
          <div class="project-notes">
            {projectNotesMap[project.id]?.slice(0, numProjectNotesOnHomepage).map((note) => (
              <a href={`/projects/${note.id}`} class="project-note">
                <span class="project-note-title"><span class="note-arrow">✦</span><span class="note-text">{note.data.title}</span></span>
              </a>
            ))}
            {(projectNotesMap[project.id]?.length ?? 0) > numProjectNotesOnHomepage && (
              <div class="all-row">
                <a href={`/projects/${project.id}`} class="all-link">see more <span class="arrow">→</span></a>
              </div>
            )}
          </div>
        </div>
      </div>
    ))}
    {hasMore && (
      <div class="all-row">
        <a href="/projects" class="all-link">see more <span class="arrow">→</span></a>
      </div>
    )}
  </section>
)}

<style>
  .projects {
    margin-top: 5rem;
  }

  .project-block + .project-block {
    margin-top: 2rem;
    padding-top: 2rem;
    border-top: 1px solid var(--c-divider);
  }

  .project-row {
    display: flex;
    gap: 2em;
  }

  .project-info {
    flex: 3 1 0;
    min-width: 0;
  }

  .project-notes {
    flex: 2 1 0;
  }

  .project-title {
    margin-top: 0;
    margin-bottom: 0.4rem;
    font-size: 1.3rem;
    font-weight: 700;
    letter-spacing: -0.02em;
  }

  .project-links {
    display: flex;
    gap: 1.1rem;
    margin-top: 0.7rem;
  }

  .project-links a {
    font-size: 0.85rem;
    color: var(--c-meta);
    text-decoration: none;
  }

  .project-links a:hover {
    color: var(--c-fg);
  }

  .project-header {
    display: flex;
    gap: 2em;
    align-items: baseline;
    margin-bottom: 0.2rem;
  }

  .project-header .project-title {
    flex: 3 1 0;
    min-width: 0;
  }

  .project-notes-label {
    flex: 2 1 0;
    margin: 0;
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--c-meta);
  }

  .project-note {
    display: block;
    text-decoration: none;
  }

  .project-note + .project-note {
    margin-top: 0.6rem;
  }

  .project-note .project-note-title {
    display: flex;
    align-items: baseline;
    gap: 0.4em;
    margin: 0;
    font-size: 0.85rem;
    font-weight: 500;
    color: var(--c-fg);
  }

  .note-arrow {
    flex-shrink: 0;
    color: var(--c-link);
    text-decoration: none;
  }

  .project-note .project-note-title .note-text {
    text-decoration-line: underline;
    text-underline-offset: 3px;
    text-decoration-thickness: 1px;
    text-decoration-color: var(--c-link);
  }

  .project-note:hover .project-note-title {
    color: var(--c-link);
  }

  .project-note .project-note-desc {
    display: block;
    margin-top: 0.25rem;
  }

  .projects :global(.entry-desc) {
    font-size: 0.96rem;
  }

  @media (max-width: 640px) {
    .project-block .project-row {
      flex-direction: column;
      gap: 1.6rem;
    }
  }
</style>
