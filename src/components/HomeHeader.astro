---
import SocialIcons from "@components/SocialIcons.astro";

interface Props {
  firstName: string;
  tagline: string;
  bio: string;
}

const { firstName, tagline, bio } = Astro.props;
---

<div class="home-header">
  <!-- <span class="zen-logo home-logo" aria-hidden="true"></span> -->
  <h1 class="home-name">I'm {firstName}</h1>
  <p class="byline">{tagline}</p>
  <p class="bio">{bio}</p>
  <SocialIcons />
</div>

<style>
  .home-header {
    margin-bottom: 2rem;
  }

  .home-name {
    font-size: 9rem;
    font-weight: 700;
    letter-spacing: -0.08em;
    margin: 0 0 0.5rem;
    line-height: 1.05;
    color: #3c3c3c;
  }

  .byline {
    font-size: 1.5rem;
    color: var(--c-desc);
  }

  .bio {
    margin: 0 0 1.8rem;
    font-size: 1.5rem;
    color: var(--c-desc);
    line-height: 1.6;
    max-width: 520px;
  }

  @media (max-width: 640px) {
    .home-name {
      font-size: 2.4rem;
    }
  }
</style>
