---
interface Props {
  date: string;
  title?: string;
  tags?: string[];
  readingTime?: string;
  backLink?: { href: string; label: string };
}

const { date, title, tags, readingTime, backLink } = Astro.props;
---

<div class="article-header">
  {backLink && (
    <div class="back-link">
      <a href={backLink.href}>← {backLink.label}</a>
    </div>
  )}

  <div class="post-meta">
    <span>{date}</span>
    {readingTime && <span>{readingTime}</span>}
    {tags?.map((tag) => (
      <a href={`/tags/${tag}`} class="tag">#{tag}</a>
    ))}
  </div>

  {title && <h1 class="post-title">{title}</h1>}

  <slot />
</div>

<style>
  .article-header {
    margin-bottom: 2rem;
  }

  .back-link {
    font-size: 0.85rem;
    margin-bottom: 1.6rem;
    color: var(--c-meta);
  }

  .back-link a {
    color: var(--c-meta);
    text-decoration: none;
  }

  .back-link a:hover {
    color: var(--c-fg);
    opacity: 1;
  }

  .post-meta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 12px;
    font-size: 0.82rem;
    color: var(--c-meta);
    margin-bottom: 1.2rem;
  }

  .tag {
    color: var(--c-meta);
    text-decoration: none;
    background: var(--c-featured-bg);
    border-radius: 99px;
    padding: 2px 10px;
    font-size: 0.78rem;
  }

  .tag:hover {
    color: var(--c-fg);
    opacity: 1;
  }

  .post-title {
    font-size: 2.4rem;
    font-weight: 700;
    letter-spacing: -0.03em;
    line-height: 1.1;
    margin: 0;
  }
</style>
