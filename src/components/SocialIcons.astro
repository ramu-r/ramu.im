---
import { SOCIALS } from "@consts";

type IconKey = "github" | "bluesky" | "email" | "link";

const FILL_ICONS: Partial<Record<IconKey, string>> = {
  github:
    "M12 2C6.477 2 2 6.477 2 12c0 4.42 2.865 8.17 6.839 9.49.5.092.682-.217.682-.482 0-.237-.009-.866-.013-1.7-2.782.604-3.369-1.34-3.369-1.34-.454-1.156-1.11-1.464-1.11-1.464-.908-.62.069-.608.069-.608 1.003.07 1.531 1.03 1.531 1.03.892 1.529 2.341 1.087 2.91.831.092-.646.35-1.086.636-1.336-2.22-.253-4.555-1.11-4.555-4.943 0-1.091.39-1.984 1.029-2.683-.103-.253-.446-1.27.098-2.647 0 0 .84-.269 2.75 1.025A9.578 9.578 0 0112 6.836c.85.004 1.705.115 2.504.337 1.909-1.294 2.747-1.025 2.747-1.025.546 1.377.203 2.394.1 2.647.64.699 1.028 1.592 1.028 2.683 0 3.842-2.339 4.687-4.566 4.935.359.309.678.919.678 1.852 0 1.336-.012 2.415-.012 2.743 0 .267.18.578.688.48C19.138 20.167 22 16.418 22 12c0-5.523-4.477-10-10-10z",
  bluesky:
    "M12 10.8c-1.087-2.114-4.046-6.053-6.798-7.995C3.566 1.266 1.5 1.108 1.5 3.551c0 .575.315 4.803.5 5.494.645 2.405 3.013 3.02 5.098 2.818l.002.002c-3.736.846-4.603 2.964-2.5 5.082 1.96 1.97 2.998.988 4.4-1.538.208-.37.412-.741.61-1.113.198.372.401.742.61 1.113 1.403 2.526 2.44 3.508 4.4 1.537 2.103-2.118 1.235-4.236-2.5-5.082l.003-.002c2.085.202 4.453-.413 5.098-2.818.185-.691.5-4.919.5-5.494 0-2.443-2.066-2.285-3.702-1.146C16.046 4.747 13.087 8.686 12 10.8z",
};

function iconKey(name: string): IconKey {
  const n = name.toLowerCase();
  if (n.includes("github")) return "github";
  if (n.includes("bluesky") || n.includes("bsky")) return "bluesky";
  if (n.includes("email") || n.includes("mail")) return "email";
  return "link";
}
---

<div class="social">
  {SOCIALS.map((s) => {
    const key = iconKey(s.NAME);
    const fillPath = FILL_ICONS[key];
    return (
      <a href={s.HREF} aria-label={s.NAME} target="_blank" rel="me noopener">
        {fillPath ? (
          <svg viewBox="0 0 24 24" fill="currentColor"><path d={fillPath} /></svg>
        ) : key === "email" ? (
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
            <rect x="2" y="4" width="20" height="16" rx="2" />
            <polyline points="22,4 12,13 2,4" />
          </svg>
        ) : (
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
            <path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71" />
            <path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71" />
          </svg>
        )}
      </a>
    );
  })}
</div>

<style>
  .social {
    display: flex;
    gap: 14px;
    margin-bottom: 3.6rem;
  }

  .social a {
    color: var(--c-label);
    text-decoration: none;
    display: block;
  }

  .social a:hover {
    opacity: 0.6;
  }

  .social svg {
    width: 19px;
    height: 19px;
    display: block;
  }
</style>
