---
import { SOCIALS, SITE } from "@consts";

const ICONS: Record<string, string> = {
  twitter:
    "M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z",
  github:
    "M12 2C6.477 2 2 6.477 2 12c0 4.42 2.865 8.17 6.839 9.49.5.092.682-.217.682-.482 0-.237-.009-.866-.013-1.7-2.782.604-3.369-1.34-3.369-1.34-.454-1.156-1.11-1.464-1.11-1.464-.908-.62.069-.608.069-.608 1.003.07 1.531 1.03 1.531 1.03.892 1.529 2.341 1.087 2.91.831.092-.646.35-1.086.636-1.336-2.22-.253-4.555-1.11-4.555-4.943 0-1.091.39-1.984 1.029-2.683-.103-.253-.446-1.27.098-2.647 0 0 .84-.269 2.75 1.025A9.578 9.578 0 0112 6.836c.85.004 1.705.115 2.504.337 1.909-1.294 2.747-1.025 2.747-1.025.546 1.377.203 2.394.1 2.647.64.699 1.028 1.592 1.028 2.683 0 3.842-2.339 4.687-4.566 4.935.359.309.678.919.678 1.852 0 1.336-.012 2.415-.012 2.743 0 .267.18.578.688.48C19.138 20.167 22 16.418 22 12c0-5.523-4.477-10-10-10z",
};

function iconKey(name: string): keyof typeof ICONS | "link" {
  const n = name.toLowerCase();
  if (n.includes("twitter") || n === "x" || n.startsWith("x ")) return "twitter";
  if (n.includes("github")) return "github";
  return "link";
}
---

<div class="social">
  {SOCIALS.map((s) => {
    const key = iconKey(s.NAME);
    return (
      <a href={s.HREF} aria-label={s.NAME} target="_blank" rel="me noopener">
        {key === "link" ? (
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
            <path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71" />
            <path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71" />
          </svg>
        ) : (
          <svg viewBox="0 0 24 24" fill="currentColor"><path d={ICONS[key]} /></svg>
        )}
      </a>
    );
  })}
  <a href={`mailto:${SITE.EMAIL}`} aria-label="Email">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
      <rect x="2" y="4" width="20" height="16" rx="2" />
      <polyline points="22,4 12,13 2,4" />
    </svg>
  </a>
</div>

<style>
  .social {
    display: flex;
    gap: 14px;
    margin-bottom: 3.6rem;
  }

  .social a {
    color: var(--c-label);
    text-decoration: none;
    display: block;
  }

  .social a:hover {
    opacity: 0.6;
  }

  .social svg {
    width: 19px;
    height: 19px;
    display: block;
  }
</style>
